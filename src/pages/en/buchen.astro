---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../content';

const locale = 'en' as const;
const t = getContent(locale);
const { buchen } = t;
---

<BaseLayout
  locale={locale}
  title={buchen.title}
  description={buchen.description}
  pathname="/en/buchen/"
  noindex={true}
>
  <section class="buchen-section" aria-labelledby="buchen-heading">
    <div class="container-content buchen-inner">
      <header class="buchen-head">
        <span class="accent-line"></span>
        <h1 id="buchen-heading" class="buchen-title">{buchen.heading}</h1>
        <p class="buchen-intro">{buchen.intro}</p>
      </header>
      <div class="tidycal-wrap">
        <div
          class="tidycal-embed"
          data-path="tobvision/15-min-project-talk"
          data-embed-height="700"
        ></div>
        <noscript>
          <a href={buchen.tidyCalUrl} class="btn-primary" target="_blank" rel="noopener">
            {t.header.ctaLabel} →
          </a>
        </noscript>
      </div>
    </div>
  </section>

  <style>
    .buchen-section {
      padding: 48px 0 96px;
      min-height: 70vh;
    }
    @media (min-width: 768px) {
      .buchen-section {
        padding: 72px 0 128px;
      }
    }
    .buchen-inner {
      max-width: 52rem;
    }
    .buchen-head {
      text-align: center;
      margin-bottom: 32px;
    }
    .buchen-head .accent-line {
      margin-bottom: 20px;
    }
    .buchen-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(2rem, 4.5vw, 2.75rem);
      letter-spacing: -0.015em;
      margin: 0 0 16px;
    }
    .buchen-intro {
      margin: 0 auto;
      color: var(--color-text-muted);
      max-width: 36rem;
      font-size: 1.0625rem;
      line-height: 1.6;
    }
    .tidycal-wrap {
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 14px;
      padding: 24px;
      min-height: 700px;
    }
    .tidycal-embed {
      width: 100%;
      min-height: 660px;
    }
  </style>

  <script src="https://asset-tidycal.b-cdn.net/js/embed.js" async></script>
</BaseLayout>
