---
import { getContent } from '../../content';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { garantie } = t;
---

<section class="garantie reveal" aria-labelledby="garantie-title">
  <div class="container-content">
    <div class="garantie-card">
      <span class="garantie-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path
            d="M12 2L3 6v6c0 5.25 3.75 10.125 9 11 5.25-.875 9-5.75 9-11V6l-9-4z"
            stroke="currentColor"
            stroke-width="1.5"
            fill="none"
          />
          <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Garantie</span>
      </span>
      <h2 id="garantie-title" class="garantie-title">{garantie.title}</h2>
      <p class="garantie-body">{garantie.body}</p>
      <p class="garantie-note">{garantie.note}</p>
    </div>
  </div>
</section>

<style>
  .garantie {
    padding: 32px 0 64px;
  }
  @media (min-width: 768px) {
    .garantie {
      padding: 48px 0 96px;
    }
  }
  .garantie-card {
    max-width: 54rem;
    margin: 0 auto;
    position: relative;
    background:
      linear-gradient(180deg, rgba(20, 30, 73, 0.42), rgba(20, 30, 73, 0.12)),
      linear-gradient(145deg, rgba(40, 40, 40, 0.68) 0%, rgba(22, 22, 22, 0.5) 100%);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(240, 237, 232, 0.09),
      inset 0 -1px 0 rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.25),
      0 14px 44px -14px rgba(0, 0, 0, 0.55);
    padding: 36px 28px;
  }
  .garantie-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg,
      rgba(200, 150, 62, 0.6) 0%,
      rgba(240, 237, 232, 0.18) 28%,
      rgba(140, 180, 220, 0.1) 48%,
      rgba(255, 215, 170, 0.12) 62%,
      rgba(240, 237, 232, 0.18) 78%,
      rgba(200, 150, 62, 0.5) 100%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 0;
  }
  .garantie-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg,
      rgba(200, 150, 62, 0.06) 0%,
      transparent 35%,
      rgba(140, 180, 220, 0.035) 52%,
      transparent 70%,
      rgba(200, 150, 62, 0.05) 100%);
    pointer-events: none;
    z-index: 0;
  }
  .garantie-card > * {
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .garantie-card {
      padding: 48px 48px;
    }
  }
  .garantie-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background-color: rgba(200, 150, 62, 0.12);
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .garantie-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 3.5vw, 2.125rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
    color: var(--color-text);
  }
  .garantie-body {
    margin: 0 0 20px;
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    line-height: 1.6;
    color: var(--color-text);
  }
  .garantie-note {
    margin: 0;
    padding: 16px 18px;
    background-color: rgba(240, 237, 232, 0.04);
    border-left: 2px solid var(--color-accent);
    border-radius: 0 6px 6px 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
</style>
