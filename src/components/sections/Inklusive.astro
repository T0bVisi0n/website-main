---
import { getContent } from '../../content';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { inklusive } = t;

function splitParenthetical(title: string): { main: string; qualifier: string | null } {
  const match = title.match(/^(.+?)\s*\(([^)]+)\)\s*$/);
  return match ? { main: match[1], qualifier: match[2] } : { main: title, qualifier: null };
}
---

<section class="inklusive reveal" aria-labelledby="inklusive-title">
  <div class="container-content">
    <header class="inklusive-head">
      <span class="accent-line"></span>
      <h2 id="inklusive-title" class="section-title">{inklusive.title}</h2>
      <p class="inklusive-intro">{inklusive.intro}</p>
    </header>
    <div class="inklusive-grid reveal-stagger">
      {inklusive.blocks.map((block) => {
        const { main, qualifier } = splitParenthetical(block.title);
        return (
          <article class="inklusive-card">
            <span class="card-number">{block.number}</span>
            <div class="card-head">
              <h3 class="card-title">{main}</h3>
              {qualifier && <p class="card-meta">{qualifier}</p>}
            </div>
            <p class="card-body">{block.body}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .inklusive {
    padding: 64px 0;
    background-color: #181818;
    position: relative;
    overflow: hidden;
  }
  .inklusive::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(560px 420px at 80% 20%, rgba(200, 150, 62, 0.08), transparent 62%),
      radial-gradient(520px 380px at 15% 80%, rgba(20, 30, 73, 0.35), transparent 68%);
  }
  .inklusive .container-content {
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .inklusive {
      padding: 96px 0;
    }
  }
  .inklusive-head {
    max-width: 40rem;
    margin-bottom: 40px;
  }
  .inklusive-head .accent-line {
    margin-bottom: 20px;
  }
  .inklusive-intro {
    margin: 16px 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2vw, 1.0625rem);
  }
  .inklusive-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .inklusive-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }
  .inklusive-card {
    position: relative;
    background:
      linear-gradient(145deg,
        rgba(30, 30, 30, 0.72) 0%,
        rgba(18, 18, 18, 0.5) 100%);
    backdrop-filter: blur(14px) saturate(155%);
    -webkit-backdrop-filter: blur(14px) saturate(155%);
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(240, 237, 232, 0.08),
      inset 0 -1px 0 rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.25),
      0 10px 32px -12px rgba(0, 0, 0, 0.5);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .inklusive-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg,
      rgba(200, 150, 62, 0.55) 0%,
      rgba(240, 237, 232, 0.14) 28%,
      rgba(140, 180, 220, 0.08) 48%,
      rgba(255, 215, 170, 0.09) 62%,
      rgba(240, 237, 232, 0.14) 78%,
      rgba(200, 150, 62, 0.45) 100%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 0;
  }
  .inklusive-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg,
      rgba(200, 150, 62, 0.05) 0%,
      transparent 35%,
      rgba(140, 180, 220, 0.03) 52%,
      transparent 70%,
      rgba(200, 150, 62, 0.04) 100%);
    pointer-events: none;
    z-index: 0;
  }
  .inklusive-card > * {
    position: relative;
    z-index: 1;
  }
  .inklusive-card:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 1px 0 rgba(240, 237, 232, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.35),
      0 2px 4px rgba(0, 0, 0, 0.3),
      0 16px 40px -12px rgba(0, 0, 0, 0.6),
      0 0 40px -10px rgba(200, 150, 62, 0.18);
  }
  .card-number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-accent);
    letter-spacing: 0;
  }
  .card-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .card-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    color: var(--color-text);
  }
  .card-meta {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .card-body {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-text-muted);
  }
</style>
