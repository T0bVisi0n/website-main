---
import { getContent } from '../../content';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { inklusive } = t;
---

<section class="inklusive" aria-labelledby="inklusive-title">
  <div class="container-content">
    <header class="inklusive-head">
      <span class="accent-line"></span>
      <h2 id="inklusive-title" class="section-title">{inklusive.title}</h2>
      <p class="inklusive-intro">{inklusive.intro}</p>
    </header>
    <div class="inklusive-grid">
      {inklusive.blocks.map((block) => (
        <article class="inklusive-card">
          <span class="card-number">{block.number}</span>
          <h3 class="card-title">{block.title}</h3>
          <p class="card-body">{block.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .inklusive {
    padding: 64px 0;
    background-color: #181818;
    position: relative;
  }
  @media (min-width: 768px) {
    .inklusive {
      padding: 96px 0;
    }
  }
  .inklusive-head {
    max-width: 40rem;
    margin-bottom: 40px;
  }
  .inklusive-head .accent-line {
    margin-bottom: 20px;
  }
  .inklusive-intro {
    margin: 16px 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2vw, 1.0625rem);
  }
  .inklusive-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .inklusive-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }
  .inklusive-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 200ms ease;
  }
  .inklusive-card:hover {
    border-color: rgba(200, 150, 62, 0.45);
  }
  .card-number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-accent);
    letter-spacing: 0;
  }
  .card-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    color: var(--color-text);
  }
  .card-body {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-text-muted);
  }
</style>
