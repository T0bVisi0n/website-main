---
import { Image } from 'astro:assets';
import headshot from '../../assets/ueber-mich.jpg';
import tuev from '../../assets/tuev-rheinland-testmark.png';
import signature from '../../assets/tobias-huber-signature-gold.png';
import { getContent } from '../../content';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { about } = t;
---

<section class="about reveal" aria-labelledby="about-title">
  <div class="container-content about-inner">
    <div class="about-photo-col">
      <div class="about-photo-wrap">
        <Image
          src={headshot}
          alt={about.photoAlt}
          widths={[400, 560, 720]}
          sizes="(min-width: 1024px) 360px, (min-width: 640px) 320px, 280px"
          loading="lazy"
          quality={82}
          class="about-photo"
        />
      </div>
      <p class="about-photo-caption">{about.photoCaption}</p>

      <aside class="trust-badge" aria-label={about.tuevAlt}>
        <div class="trust-mark-frame">
          <Image
            src={tuev}
            alt={about.tuevAlt}
            widths={[160, 240]}
            sizes="100px"
            loading="lazy"
            quality={90}
            class="trust-mark"
          />
        </div>
        <div class="trust-text">
          <p class="trust-line-1">TÜV Rheinland zertifiziert</p>
          <p class="trust-line-2">Copywriting + Marketingstrategie</p>
        </div>
      </aside>
    </div>

    <div class="about-body">
      <span class="accent-line"></span>
      <h2 id="about-title" class="section-title">{about.title}</h2>
      <div class="about-text">
        {about.paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
      <div class="about-signature">
        <Image
          src={signature}
          alt={about.signatureAlt}
          widths={[200, 300]}
          sizes="220px"
          loading="lazy"
          quality={85}
          class="signature-img"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    padding: 64px 0;
    background-color: transparent;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .about {
      padding: 96px 0;
    }
  }
  .about-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .about-inner {
      grid-template-columns: minmax(0, 340px) minmax(0, 1fr);
      gap: 64px;
    }
  }
  .about-photo-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    max-width: 340px;
  }
  .about-photo-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.6);
  }
  .about-photo {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .about-photo-caption {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .trust-badge {
    margin-top: 16px;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }
  .trust-mark-frame {
    flex-shrink: 0;
    width: 72px;
    height: 36px;
    background-color: #f0ede8;
    border-radius: 6px;
    padding: 4px 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .trust-mark {
    max-width: 100%;
    max-height: 100%;
    height: auto;
    width: auto;
    object-fit: contain;
    display: block;
  }
  .trust-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .trust-line-1 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }
  .trust-line-2 {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
  .about-body .accent-line {
    margin-bottom: 20px;
  }
  .about-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 24px;
    max-width: 44rem;
  }
  .about-text p {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--color-text);
  }
  .about-signature {
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--color-border);
  }
  .signature-img {
    width: 220px;
    height: auto;
    max-width: 100%;
    display: block;
    opacity: 0.95;
  }
</style>
