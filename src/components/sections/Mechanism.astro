---
import { getContent } from '../../content';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { mechanism } = t;
---

<section class="mechanism reveal" aria-labelledby="mechanism-title">
  <div class="container-content">
    <header class="mechanism-head">
      <span class="accent-line"></span>
      <h2 id="mechanism-title" class="section-title">{mechanism.title}</h2>
      <p class="mechanism-intro">{mechanism.intro}</p>
    </header>
    <ol class="mechanism-steps reveal-stagger">
      {mechanism.steps.map((step) => (
        <li class="mechanism-step">
          <span class="step-number">{step.number}</span>
          <div class="step-body">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-text">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .mechanism {
    padding: 64px 0;
    background-color: transparent;
    position: relative;
    overflow: hidden;
  }
  .mechanism::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    z-index: 2;
  }
  .mechanism::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(620px 440px at 15% 25%, rgba(212, 169, 74, 0.09), transparent 62%),
      radial-gradient(540px 400px at 85% 75%, rgba(60, 90, 160, 0.14), transparent 70%);
  }
  .mechanism .container-content {
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .mechanism {
      padding: 96px 0;
    }
  }
  .mechanism-head {
    max-width: 46rem;
    margin-bottom: 48px;
  }
  .mechanism-head .accent-line {
    margin-bottom: 20px;
  }
  .mechanism-intro {
    margin: 16px 0 0;
    font-size: clamp(1rem, 2.1vw, 1.125rem);
    color: var(--color-text-muted);
    max-width: 40rem;
  }
  .mechanism-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .mechanism-steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (min-width: 1024px) {
    .mechanism-steps {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .mechanism-step {
    position: relative;
    background:
      linear-gradient(145deg,
        rgba(40, 40, 40, 0.72) 0%,
        rgba(26, 26, 26, 0.52) 100%);
    backdrop-filter: blur(14px) saturate(155%);
    -webkit-backdrop-filter: blur(14px) saturate(155%);
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(240, 237, 232, 0.08),
      inset 0 -1px 0 rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.25),
      0 10px 32px -12px rgba(0, 0, 0, 0.5);
    padding: 28px 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mechanism-step::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg,
      rgba(212, 169, 74, 0.55) 0%,
      rgba(240, 237, 232, 0.14) 28%,
      rgba(140, 180, 220, 0.08) 48%,
      rgba(255, 215, 170, 0.09) 62%,
      rgba(240, 237, 232, 0.14) 78%,
      rgba(212, 169, 74, 0.45) 100%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 0;
  }
  .mechanism-step::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg,
      rgba(212, 169, 74, 0.05) 0%,
      transparent 35%,
      rgba(140, 180, 220, 0.03) 52%,
      transparent 70%,
      rgba(212, 169, 74, 0.04) 100%);
    pointer-events: none;
    z-index: 0;
  }
  .mechanism-step > * {
    position: relative;
    z-index: 1;
  }
  .mechanism-step:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 1px 0 rgba(240, 237, 232, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.35),
      0 2px 4px rgba(0, 0, 0, 0.3),
      0 16px 40px -12px rgba(0, 0, 0, 0.6),
      0 0 40px -10px rgba(212, 169, 74, 0.18);
  }
  .step-number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    color: var(--color-accent);
    letter-spacing: 0;
    line-height: 1;
  }
  .step-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .step-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.3;
    color: var(--color-text);
  }
  .step-text {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
</style>
