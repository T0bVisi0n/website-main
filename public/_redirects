# Root redirect - DE is default locale
# `!` force-flag overrides the static index.html fallback (which is only there
# for the Astro build requirement + as a no-JS meta-refresh safety net).
/                       /de/                  301!

# Locale-aware 404s (Netlify sends these if nothing else matches)
/de/*                   /de/404/index.html    404
/en/*                   /en/404/index.html    404
/*                      /de/404/index.html    404
